# Storefront environment (.env.local için şablon). Secret değer KOYMAYIN.

# Medusa backend publishable API key (ZORUNLU). Admin → Settings → Publishable API Keys.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_xxx

# Medusa backend API URL (ZORUNLU). Örn. http://localhost:9000
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Storefront genel (public) temel URL. Canonical / OG / sitemap için kullanılır.
# Production'da ZORUNLU ve HTTPS olmalı. Dev'de boşsa http://localhost:8000'a düşer.
NEXT_PUBLIC_BASE_URL=https://localhost:8000

# Varsayılan region/ülke kodu (region ülkeleriyle eşleşmeli).
NEXT_PUBLIC_DEFAULT_REGION=tr

# On-demand cache invalidation guard'ı (POST /api/revalidate?secret=...). Boşsa uç 503 döner.
REVALIDATE_SECRET=

# Stripe (opsiyonel — ödeme bu MVP kapsamı dışı).
NEXT_PUBLIC_STRIPE_KEY=

# Medusa Cloud S3 görsel host (opsiyonel; image remotePatterns için).
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=

# Node ortamı.
NODE_ENV=development
