# Storefront production env şablonu. GERÇEK SECRET KOYMAYIN; deploy ortamında set edin.
# (check-env-variables.js: production'da eksik key/backend URL ve HTTPS olmayan base URL fail-fast.)

NODE_ENV=production

# ── ZORUNLU ──────────────────────────────────────────────────────────────────
# Backend admin'den üretilen publishable API key.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_xxx

# Backend API'nin PUBLIC URL'i (tarayıcıdan erişilebilir). Production'da HTTPS.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.example.com

# Storefront public base URL. Canonical / OG / sitemap için; production'da HTTPS ZORUNLU.
NEXT_PUBLIC_BASE_URL=https://shop.example.com

# Varsayılan region/ülke kodu (backend region ülkeleriyle eşleşmeli).
NEXT_PUBLIC_DEFAULT_REGION=tr

# ── ÖNERİLEN ─────────────────────────────────────────────────────────────────
# /api/revalidate guard secret'ı (katalog değişiminden sonra cache purge).
# Boşsa uç 503 döner (kapalı). Üretim: `openssl rand -hex 24`.
REVALIDATE_SECRET=__SET_STRONG_SECRET__

# ── OPSİYONEL ────────────────────────────────────────────────────────────────
# Ürün görsellerinin geldiği S3 host (next/image remotePatterns için).
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=

# Stripe (ödeme bu MVP kapsamı dışı).
NEXT_PUBLIC_STRIPE_KEY=
