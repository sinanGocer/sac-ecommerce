# ── İzole ENTEGRASYON TEST ortamı (lot-costing) ──────────────────────────────
#
# Bu dosyayı `.env.test` olarak KOPYALAYIN (`.env.test` COMMIT EDİLMEZ).
# Entegrasyon testleri YALNIZ ayrı bir "_test" veritabanına bağlanır; gerçek
# development/production verisine (74 published ürün) ASLA dokunmaz.
#
# FAIL-CLOSED guard'lar (src/inventory-costing/__integration__/test-db.ts):
#   - DB adında "_test" yoksa testler başlamaz
#   - NODE_ENV != test ise destructive setup yapılmaz
#   - bilinen dev/prod DB adı algılanırsa abort
#   - secret'lar loglanmaz (URL maskelenir)

# Zorunlu: NODE_ENV test olmalı (script bunu zaten ayarlar).
NODE_ENV=test

# İzole test veritabanı. Adı MUTLAKA "_test" içermeli.
# Önce oluşturun:  createdb medusa_sac_ecommerce_test
TEST_DATABASE_URL=postgres://postgres@localhost/medusa_sac_ecommerce_test

# Feature flag'ler test process'i içinde, yalnız gerekli testte açılır.
# Örnek dosyada VARSAYILAN KAPALI tutulur (production örneklerinde de false).
LOT_COSTING_WRITE_ENABLED=false
LOT_COSTING_FIFO_ENABLED=false
LOT_COSTING_JOBS_ENABLED=false
