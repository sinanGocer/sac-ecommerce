# Backend production env şablonu. GERÇEK SECRET KOYMAYIN; deploy ortamında set edin.
# (validate-env.ts: NODE_ENV=production iken eksik/zayıf değerlerde süreç fail-fast.)

NODE_ENV=production

# ── ZORUNLU ──────────────────────────────────────────────────────────────────
# Managed PostgreSQL bağlantısı. Production'da SSL önerilir (?sslmode=require).
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/medusa?sslmode=require

# Güçlü, rastgele secret'lar (>=32 bayt). "supersecret" gibi placeholder'lar
# production'da fail-fast ile reddedilir. Üretim: `openssl rand -base64 32`.
JWT_SECRET=__SET_STRONG_SECRET__
COOKIE_SECRET=__SET_STRONG_SECRET__

# CORS — storefront ve admin gerçek domain'leri (virgülle).
STORE_CORS=https://shop.example.com
ADMIN_CORS=https://admin.example.com
AUTH_CORS=https://shop.example.com,https://admin.example.com

# ── ÖNERİLEN ─────────────────────────────────────────────────────────────────
# Redis (event bus + workflow engine + cache modülleri). Yoksa in-memory fake
# kullanılır (tek instance dışında önerilmez).
REDIS_URL=redis://HOST:6379

# Admin auth MFA şifreleme anahtarı (varsa).
AUTH_MFA_ENCRYPTION_KEY=__SET_STRONG_SECRET__

# ── OPSİYONEL: İyzico (bu MVP'de KAPALI; gerçek merchant gelince) ─────────────
IYZICO_PROVIDER_ENABLED=false
# IYZICO_PROVIDER_ENABLED=true iken validate-env şunları ZORUNLU kılar:
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_MODE=sandbox
IYZICO_NETWORK_ENABLED=false
IYZICO_CALLBACK_URL=
IYZICO_RETURN_URL=
IYZICO_WEBHOOK_SECRET=

# ── OPSİYONEL: Medusa Cloud S3 (görsel) ──────────────────────────────────────
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=
